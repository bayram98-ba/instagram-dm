generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  // Local dev: sqlite  |  Production (Vercel): postgresql
  // Change to "postgresql" after setting DATABASE_URL to Neon connection string
  provider = "sqlite"
}

model Customer {
  id        String   @id @default(cuid())
  name      String?
  phone     String?
  address   String?
  createdAt DateTime @default(now())

  conversations Conversation[]
  orders        Order[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  price       Float
  variants    String   // JSON array: ["Qara","Bej","Ağ"]
  stock       Int      @default(0)
  description String?
  category    String?
  salesCount  Int      @default(0)
  emoji       String   @default("📦")
  tone        String   @default("#9aa0a6")
  createdAt   DateTime @default(now())

  orders Order[]
}

model Conversation {
  id            String   @id @default(cuid())
  customerId    String?
  channel       String   @default("test")  // "test" | "instagram"
  mode          String   @default("semi")  // "semi" | "auto"
  unreadCount   Int      @default(0)
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())

  customer Customer?  @relation(fields: [customerId], references: [id])
  messages Message[]
  orders   Order[]
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  direction      String   // "incoming" | "outgoing"
  text           String
  isAiGenerated  Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Order {
  id             String   @id @default(cuid())
  conversationId String
  customerId     String?
  productId      String?
  productName    String?
  variant        String?
  qty            Int      @default(1)
  customerName   String?
  phone          String?
  address        String?
  zone           String?
  deliveryFee    Float    @default(0)
  paymentMethod  String?
  total          Float    @default(0)
  status         String   @default("Yeni")  // Yeni | Təsdiqlənib | Göndərilib
  aiFilledFields String   @default("[]")    // JSON array of field names filled by AI
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  customer     Customer?    @relation(fields: [customerId], references: [id])
  product      Product?     @relation(fields: [productId], references: [id])
}

model Setting {
  key       String   @id
  value     String   // JSON
  updatedAt DateTime @updatedAt
}
