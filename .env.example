# Claude / Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Database (SQLite üçün fayl yolu)
DATABASE_URL="file:./dev.db"

# ── Instagram / Meta Webhooks ──────────────────────────────────────────
# Meta Developer Panel → App → Webhooks bölməsindən əldə edilir

# Özünüz seçdiyiniz istənilən gizli söz — webhook verify üçün
META_VERIFY_TOKEN=sifarish-webhook-secret

# Meta App → App Secret
META_APP_SECRET=

# Page Access Token (uzun ömürlü) — Graph API vasitəsilə alınır
META_PAGE_ACCESS_TOKEN=

# Instagram Business hesabının ID-si (isteğe bağlı)
META_INSTAGRAM_ACCOUNT_ID=
